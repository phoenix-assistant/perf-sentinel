{
  "name": "@phoenixaihub/perf-sentinel",
  "version": "0.1.0",
  "description": "Performance regression CI gate with statistical testing and auto-bisect",
  "main": "dist/cli.js",
  "bin": {
    "perf-sentinel": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "performance",
    "benchmark",
    "ci",
    "regression",
    "testing"
  ],
  "author": "PhoenixAI Hub",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "eslint": "^8.56.0",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/phoenix-assistant/perf-sentinel.git"
  },
  "homepage": "https://github.com/phoenix-assistant/perf-sentinel#readme"
}
